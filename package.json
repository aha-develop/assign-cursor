{
  "name": "aha-develop.assign-cursor",
  "description": "Cursor Cloud Agent",
  "version": "1.0.0",
  "author": "Aha! (support@aha.io)",
  "repository": {
    "type": "git",
    "url": "https://github.com/aha-develop/assign-cursor"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/base-64": "^1.0.2",
    "@types/react": "^16.14.68",
    "aha-cli": "^1.17.0",
    "prettier": "^3.8.0"
  },
  "ahaExtension": {
    "contributes": {
      "views": {
        "sendToCursorButton": {
          "title": "Cursor",
          "entryPoint": "src/views/SendToCursorButton.tsx",
          "host": "attribute",
          "recordTypes": [
            "Feature",
            "Requirement"
          ]
        }
      },
      "events": {
        "createCursorAgent": {
          "title": "Create Cursor Agent",
          "entryPoint": "src/events/createCursorAgent.ts",
          "handles": [
            "aha-develop.assign-cursor.createCursorAgent"
          ]
        }
      },
      "settings": {
        "repository": {
          "title": "GitHub Repository",
          "description": "Format: https://github.com/your-org/your-repo. Must be accessible to Cursor Cloud Agent.",
          "type": "string",
          "required": true,
          "scope": [
            "account",
            "user"
          ]
        },
        "baseBranch": {
          "title": "Base Branch",
          "description": "Repository's default branch",
          "type": "string",
          "default": "main",
          "scope": [
            "account",
            "user"
          ]
        },
        "apiKey": {
          "title": "API Key",
          "description": "Cursor API key from Cursor Dashboard",
          "type": "secret",
          "scope": [
            "account"
          ],
          "required": true
        },
        "customInstructions": {
          "title": "Custom Instructions",
          "description": "Optional extra guidance appended to the agent prompt.",
          "type": "string",
          "scope": [
            "account",
            "user"
          ]
        }
      }
    }
  },
  "dependencies": {
    "base-64": "^1.0.0",
    "zod": "^4.3.5"
  }
}
